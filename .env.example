# Vantage Medical Office — Environment Variables
# Copy this file to .env and fill in values when connecting to real backend.

# API base URL (leave empty for demo mode)
VITE_API_BASE_URL=

# AWS S3 (frontend reference only — real credentials go on the backend)
VITE_S3_BUCKET=vantage-uploads
VITE_S3_REGION=us-east-1

# Zoom Phone (frontend reference only)
VITE_ZOOM_PHONE_NUMBER=
