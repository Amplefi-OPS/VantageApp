{
  "name": "vantage",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web",
    "packages/infra"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@vantage/web",
    "build": "npm run build --workspace=@vantage/web",
    "deploy": "npm run deploy --workspace=@vantage/infra",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:web": "npm run dev --workspace=@vantage/web",
    "build:web": "npm run build --workspace=@vantage/web",
    "build:infra": "npm run build --workspace=@vantage/infra",
    "deploy:infra": "npm run deploy --workspace=@vantage/infra",
    "synth": "npm run synth --workspace=@vantage/infra"
  },
  "dependencies": {
    "esbuild": "^0.25.12"
  }
}
